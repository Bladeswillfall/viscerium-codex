---
import EditLink from 'virtual:starlight/components/EditLink';
import LastUpdated from 'virtual:starlight/components/LastUpdated';
import Pagination from 'virtual:starlight/components/Pagination';
import GiscusComments from './GiscusComments.astro';
---

<button
  class="codex-sidebar-toggle"
  type="button"
  data-codex-sidebar-toggle
  aria-expanded="true"
  aria-label="Hide sidebar"
  title="Hide sidebar"
>
  <span aria-hidden="true">←</span>
</button>

<GiscusComments />

<footer class="sl-flex">
  <div class="meta sl-flex">
    <EditLink />
    <LastUpdated />
  </div>
  <Pagination />
</footer>

<script is:inline>
  (() => {
    const storageKey = 'viscerium-sidebar-collapsed';
    const root = document.documentElement;
    const button = document.querySelector('[data-codex-sidebar-toggle]');

    if (!button) return;

    const setCollapsed = (collapsed) => {
      root.classList.toggle('codex-sidebar-collapsed', collapsed);
      button.setAttribute('aria-expanded', String(!collapsed));
      button.setAttribute('aria-label', collapsed ? 'Show sidebar' : 'Hide sidebar');
      button.setAttribute('title', collapsed ? 'Show sidebar' : 'Hide sidebar');
      button.querySelector('span').textContent = collapsed ? '☰' : '←';
    };

    setCollapsed(localStorage.getItem(storageKey) === 'true');

    button.addEventListener('click', () => {
      const collapsed = !root.classList.contains('codex-sidebar-collapsed');
      localStorage.setItem(storageKey, String(collapsed));
      setCollapsed(collapsed);
    });
  })();
</script>

<style>
  @layer starlight.core {
    footer {
      flex-direction: column;
      gap: 1.5rem;
    }
    .meta {
      gap: 0.75rem 3rem;
      justify-content: space-between;
      flex-wrap: wrap;
      margin-top: 3rem;
      font-size: var(--sl-text-sm);
      color: var(--sl-color-gray-3);
    }
    .meta > :global(p:only-child) {
      margin-inline-start: auto;
    }
  }
</style>
