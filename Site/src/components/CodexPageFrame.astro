---
import DefaultPageFrame from '@astrojs/starlight/components/PageFrame.astro';
import CodexFooterRail from './CodexFooterRail.astro';
---

<DefaultPageFrame>
  <slot name="header" slot="header" />
  <slot name="sidebar" slot="sidebar" />
  <slot />
</DefaultPageFrame>

<CodexFooterRail />

<style is:global>
  @layer ion {
    /*
     * The navigation rail is a true page-level underlay, not an article-column
     * descendant. Keep the negative layer local to the document so it remains
     * above the body background while the raised Starlight page paints over it.
     */
    body {
      position: relative;
      isolation: isolate;
    }

    .page {
      position: relative;
      z-index: var(--codex-z-page, 0);
      border-radius: 0 0 1.25rem 1.25rem;
      background: var(--codex-page-bg);
      box-shadow:
        0 1.5rem 3.4375rem color-mix(in oklch, var(--codex-shadow-color) 46%, transparent),
        0 1px 0 var(--sl-color-hairline-light);
    }

    @media (max-width: 40rem) {
      .page {
        border-radius: 0 0 1rem 1rem;
      }
    }

    @media print, (forced-colors: active) {
      .page {
        border-radius: 0;
        box-shadow: none;
      }
    }
  }
</style>
