<codex-theme-toggle>
  <button
    class="theme-toggle"
    type="button"
    data-codex-theme-toggle
    aria-label="Switch colour theme"
    title="Switch colour theme"
  >
    <svg class="theme-icon theme-icon--sun" aria-hidden="true" viewBox="0 0 24 24">
      <circle cx="12" cy="12" r="3.5"></circle>
      <path d="M12 2v2.25M12 19.75V22M4.93 4.93l1.6 1.6M17.47 17.47l1.6 1.6M2 12h2.25M19.75 12H22M4.93 19.07l1.6-1.6M17.47 6.53l1.6-1.6"></path>
    </svg>
    <svg class="theme-icon theme-icon--moon" aria-hidden="true" viewBox="0 0 24 24">
      <path d="M20.2 15.4A8.5 8.5 0 0 1 8.6 3.8 8.5 8.5 0 1 0 20.2 15.4Z"></path>
    </svg>
  </button>
</codex-theme-toggle>

<script>
  const storageKey = 'starlight-theme';

  if (!customElements.get('codex-theme-toggle')) {
    customElements.define(
      'codex-theme-toggle',
      class extends HTMLElement {
        connectedCallback() {
          if (this.dataset.bound === 'true') return;

          const button = this.querySelector('[data-codex-theme-toggle]');
          if (!(button instanceof HTMLButtonElement)) return;

          const currentTheme = () =>
            document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';

          const syncLabel = () => {
            const nextTheme = currentTheme() === 'dark' ? 'light' : 'dark';
            const label = `Switch to ${nextTheme} mode`;
            button.setAttribute('aria-label', label);
            button.setAttribute('title', label);
          };

          button.addEventListener('click', () => {
            const nextTheme = currentTheme() === 'dark' ? 'light' : 'dark';
            document.documentElement.dataset.theme = nextTheme;
            document.documentElement.style.colorScheme = nextTheme;
            localStorage.setItem(storageKey, nextTheme);
            syncLabel();
          });

          this.dataset.bound = 'true';
          syncLabel();
        }
      }
    );
  }
</script>

<style>
  @layer starlight.core {
    codex-theme-toggle {
      display: inline-flex;
    }

    .theme-toggle {
      display: inline-grid;
      width: 2.5rem;
      height: 2.5rem;
      place-items: center;
      border: 1px solid var(--sl-color-gray-5);
      border-radius: 0;
      background: var(--sl-color-black);
      color: var(--sl-color-gray-2);
      cursor: pointer;
      transition: border-color .15s ease, background-color .15s ease, color .15s ease;
    }

    .theme-toggle:hover {
      border-color: var(--sl-color-gray-2);
      background: var(--codex-surface-accent);
      color: var(--sl-color-white);
    }

    .theme-toggle:focus-visible {
      outline: 2px solid var(--sl-color-accent-high);
      outline-offset: 2px;
    }

    .theme-icon {
      width: 1.1rem;
      height: 1.1rem;
      fill: none;
      stroke: currentColor;
      stroke-width: 1.75;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    :global(:root[data-theme='dark']) .theme-icon--moon,
    :global(:root[data-theme='light']) .theme-icon--sun {
      display: none;
    }
  }
</style>
