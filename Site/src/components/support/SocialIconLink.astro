---
import LocalIcon from '../LocalIcon.astro';

interface Props {
  label: string;
  icon: string;
  href?: string;
  placeholder?: boolean;
}

const { label, icon, href, placeholder = false } = Astro.props as Props;
const isLive = Boolean(href) && !placeholder;
---

{isLive ? (
  <a class="social-icon-link" href={href} target="_blank" rel="noreferrer" aria-label={label} title={label}>
    <span class="social-icon-link__icon"><LocalIcon name={icon} /></span>
    <span class="social-icon-link__label">{label}</span>
  </a>
) : (
  <div class="social-icon-link social-icon-link--placeholder" aria-disabled="true" title={`${label} coming soon`}>
    <span class="social-icon-link__icon"><LocalIcon name={icon} /></span>
    <span class="social-icon-link__label">{label}</span>
    <span class="social-icon-link__status">Coming soon</span>
  </div>
)}
