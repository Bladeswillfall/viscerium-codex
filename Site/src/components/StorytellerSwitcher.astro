---
const { starlightRoute } = Astro.locals;
const storyteller = starlightRoute.entry.data.storyteller;
const sections = storyteller?.sections ?? [];
const hasStoryteller = sections.length > 0;
const eraStyle = starlightRoute.entry.data.eraStyle;
---

{hasStoryteller && (
  <div
    class="codex-article-view-switcher"
    data-codex-view-root
    data-view="lore"
    data-era-style={eraStyle}
  >
    <div class="codex-article-view-tabs" role="tablist" aria-label="Article view">
      <button
        id="codex-tab-lore"
        class="codex-article-view-tab"
        type="button"
        role="tab"
        aria-selected="true"
        tabindex="0"
        data-codex-view-tab="lore"
      >
        Lore
      </button>
      <button
        id="codex-tab-storyteller"
        class="codex-article-view-tab"
        type="button"
        role="tab"
        aria-selected="false"
        tabindex="-1"
        aria-controls="codex-storyteller-panel"
        data-codex-view-tab="storyteller"
      >
        Storyteller
      </button>
    </div>

    <section
      id="codex-storyteller-panel"
      class="codex-storyteller-panel"
      role="tabpanel"
      aria-labelledby="codex-tab-storyteller"
      tabindex="0"
      hidden
      data-codex-storyteller-panel
    >
      <header class="codex-storyteller-intro">
        <p class="codex-kicker">Storyteller</p>
        <p>Concise, system-agnostic handles for using this subject in scenes, journeys and stories.</p>
      </header>

      {sections.map((section) => (
        <section class="codex-storyteller-section" aria-labelledby={`storyteller-${section.id}`}>
          <h2 id={`storyteller-${section.id}`}>{section.title}</h2>
          <dl class="codex-storyteller-facts">
            {section.items.map((item) => (
              <div class="codex-storyteller-fact">
                <dt>{item.label}</dt>
                <dd>
                  {Array.isArray(item.value)
                    ? item.value.map((value) => <span class="codex-storyteller-value">{value}</span>)
                    : item.value}
                </dd>
              </div>
            ))}
          </dl>
        </section>
      ))}
    </section>
  </div>
)}

<script>
  function initialiseStorytellerSwitcher() {
    const roots = [...document.querySelectorAll('[data-codex-view-root]')];
    if (!roots.length) {
      delete document.documentElement.dataset.codexArticleView;
      return;
    }

    for (const root of roots) {
      if (!(root instanceof HTMLElement) || root.dataset.initialised === 'true') continue;
      const main = root.closest('main');
      const lorePanel = main?.querySelector('.sl-markdown-content');
      const storytellerPanel = root.querySelector('[data-codex-storyteller-panel]');
      const tabs = [...root.querySelectorAll('[data-codex-view-tab]')];
      if (!(lorePanel instanceof HTMLElement) || !(storytellerPanel instanceof HTMLElement) || !tabs.length) continue;

      const lorePanelId = lorePanel.id || 'codex-lore-panel';
      lorePanel.id = lorePanelId;
      lorePanel.setAttribute('role', 'tabpanel');
      lorePanel.setAttribute('aria-labelledby', 'codex-tab-lore');
      const loreTab = root.querySelector('[data-codex-view-tab="lore"]');
      if (loreTab instanceof HTMLElement) loreTab.setAttribute('aria-controls', lorePanelId);

      const activate = (view, moveFocus = false) => {
        const storytellerActive = view === 'storyteller';
        lorePanel.hidden = storytellerActive;
        storytellerPanel.hidden = !storytellerActive;
        root.dataset.view = storytellerActive ? 'storyteller' : 'lore';
        document.documentElement.dataset.codexArticleView = root.dataset.view;

        for (const tab of tabs) {
          if (!(tab instanceof HTMLButtonElement)) continue;
          const selected = tab.dataset.codexViewTab === root.dataset.view;
          tab.setAttribute('aria-selected', String(selected));
          tab.tabIndex = selected ? 0 : -1;
          if (selected && moveFocus) tab.focus();
        }
      };

      for (const tab of tabs) {
        if (!(tab instanceof HTMLButtonElement)) continue;
        tab.addEventListener('click', () => activate(tab.dataset.codexViewTab));
        tab.addEventListener('keydown', (event) => {
          if (!['ArrowLeft', 'ArrowRight', 'Home', 'End'].includes(event.key)) return;
          event.preventDefault();
          const currentIndex = tabs.indexOf(tab);
          let nextIndex = currentIndex;
          if (event.key === 'ArrowLeft') nextIndex = (currentIndex - 1 + tabs.length) % tabs.length;
          if (event.key === 'ArrowRight') nextIndex = (currentIndex + 1) % tabs.length;
          if (event.key === 'Home') nextIndex = 0;
          if (event.key === 'End') nextIndex = tabs.length - 1;
          const next = tabs[nextIndex];
          if (next instanceof HTMLButtonElement) activate(next.dataset.codexViewTab, true);
        });
      }

      root.dataset.initialised = 'true';
      activate('lore');
    }
  }

  initialiseStorytellerSwitcher();
  document.addEventListener('astro:page-load', initialiseStorytellerSwitcher);
</script>

<style is:global>
  .codex-article-view-switcher {
    --view-tab-accent: var(--era-link-hover, var(--sl-color-accent-high));
    --view-tab-active: color-mix(in oklch, var(--era-button, var(--codex-surface-raised-color)) 72%, var(--codex-palette-deep));
    --view-tab-inactive: color-mix(in oklch, var(--codex-surface-raised-color) 86%, transparent);
    --view-tab-border: color-mix(in oklch, var(--view-tab-accent) 40%, var(--sl-color-hairline));
    margin-block: 1.15rem 1.9rem;
  }

  .codex-article-view-tabs {
    position: relative;
    display: flex;
    align-items: end;
    inline-size: fit-content;
    max-inline-size: 100%;
    gap: .25rem;
    padding-inline: .15rem;
    border-block-end: 1px solid var(--view-tab-border);
  }

  .codex-article-view-tab {
    position: relative;
    appearance: none;
    min-inline-size: 7.75rem;
    margin: 0 0 -1px;
    border: 1px solid var(--view-tab-border);
    border-block-end: 0;
    padding: .72rem 1.15rem .68rem;
    background: var(--view-tab-inactive);
    color: var(--sl-color-gray-3);
    font: inherit;
    font-size: var(--sl-text-sm);
    font-weight: 650;
    letter-spacing: .045em;
    line-height: 1;
    text-align: center;
    cursor: pointer;
    transition:
      color 140ms ease,
      background 140ms ease,
      transform 140ms ease,
      filter 140ms ease;
  }

  .codex-article-view-tab:hover {
    color: var(--sl-color-white);
    background: color-mix(in oklch, var(--view-tab-active) 72%, var(--view-tab-inactive));
  }

  .codex-article-view-tab:focus-visible {
    color: var(--sl-color-white);
    outline: 2px solid var(--view-tab-accent);
    outline-offset: 3px;
  }

  .codex-article-view-tab[aria-selected='true'] {
    z-index: 3;
    background: var(--view-tab-active);
    color: var(--sl-color-white);
    transform: translateY(-.18rem);
  }

  /*
    CITADEL: physical chronicle dividers. Broad, overlapping folder tabs with
    slanted shoulders; the active leaf sits visibly in front of its neighbour.
  */
  .codex-article-view-switcher[data-era-style='e1'] .codex-article-view-tabs {
    gap: 0;
    padding-inline-start: .1rem;
  }

  .codex-article-view-switcher[data-era-style='e1'] .codex-article-view-tab {
    min-inline-size: 9.25rem;
    padding: .78rem 1.65rem .72rem;
    border: 0;
    clip-path: polygon(.72rem 0, calc(100% - 1.05rem) 0, 100% 100%, 0 100%);
    box-shadow: inset 0 1px 0 color-mix(in oklch, var(--view-tab-accent) 28%, transparent);
  }

  .codex-article-view-switcher[data-era-style='e1'] .codex-article-view-tab + .codex-article-view-tab {
    margin-inline-start: -.55rem;
  }

  .codex-article-view-switcher[data-era-style='e1'] .codex-article-view-tab[aria-selected='true'] {
    z-index: 4;
    padding-inline: 1.9rem;
    filter: drop-shadow(0 -.18rem .22rem rgb(0 0 0 / .16));
  }

  /*
    SMOG: stamped industrial plates. Shorter tabs, clipped opposing corners and
    deliberate air between controls make the switch feel bolted onto machinery.
  */
  .codex-article-view-switcher[data-era-style='e2'] .codex-article-view-tabs {
    gap: .48rem;
    padding-block-end: .16rem;
    border-block-end-width: 2px;
  }

  .codex-article-view-switcher[data-era-style='e2'] .codex-article-view-tab {
    min-inline-size: 8.4rem;
    padding: .62rem 1.15rem .58rem;
    border: 0;
    clip-path: polygon(0 .38rem, .38rem 0, 100% 0, 100% calc(100% - .38rem), calc(100% - .38rem) 100%, 0 100%);
    letter-spacing: .085em;
    text-transform: uppercase;
  }

  .codex-article-view-switcher[data-era-style='e2'] .codex-article-view-tab::after {
    content: '';
    position: absolute;
    inset: auto .58rem .34rem;
    block-size: 1px;
    background: color-mix(in oklch, var(--view-tab-accent) 28%, transparent);
  }

  .codex-article-view-switcher[data-era-style='e2'] .codex-article-view-tab[aria-selected='true']::after {
    block-size: 2px;
    background: var(--view-tab-accent);
  }

  /*
    NEARSIGHT: mode wedges. A tighter, directional silhouette reads more like a
    field interface than a document tab while retaining the same accessible hit area.
  */
  .codex-article-view-switcher[data-era-style='e3'] .codex-article-view-tabs {
    gap: .38rem;
    border-block-end: 0;
  }

  .codex-article-view-switcher[data-era-style='e3'] .codex-article-view-tab {
    min-inline-size: 8.7rem;
    padding: .66rem 1.5rem;
    border: 0;
    clip-path: polygon(0 0, calc(100% - .75rem) 0, 100% 50%, calc(100% - .75rem) 100%, 0 100%, .42rem 50%);
    letter-spacing: .06em;
  }

  .codex-article-view-switcher[data-era-style='e3'] .codex-article-view-tab[aria-selected='true'] {
    transform: translateX(.16rem);
    filter: drop-shadow(-.22rem 0 0 color-mix(in oklch, var(--view-tab-accent) 65%, transparent));
  }

  /*
    ENTROPY: fractured brackets. The control sheds most of its solid mass and
    uses offset geometry instead, as if the interface is only partially coherent.
  */
  .codex-article-view-switcher[data-era-style='e4'] .codex-article-view-tabs {
    gap: .58rem;
    padding-block: .16rem .22rem;
    border-block-end: 0;
  }

  .codex-article-view-switcher[data-era-style='e4'] .codex-article-view-tab {
    min-inline-size: 8.35rem;
    border: 0;
    padding: .66rem 1.2rem;
    background: color-mix(in oklch, var(--view-tab-inactive) 62%, transparent);
    clip-path: polygon(.78rem 0, 100% 0, calc(100% - .78rem) 100%, 0 100%);
  }

  .codex-article-view-switcher[data-era-style='e4'] .codex-article-view-tab::before,
  .codex-article-view-switcher[data-era-style='e4'] .codex-article-view-tab::after {
    content: '';
    position: absolute;
    pointer-events: none;
    background: var(--view-tab-accent);
    opacity: .48;
  }

  .codex-article-view-switcher[data-era-style='e4'] .codex-article-view-tab::before {
    inset: .22rem auto .22rem .42rem;
    inline-size: 1px;
  }

  .codex-article-view-switcher[data-era-style='e4'] .codex-article-view-tab::after {
    inset: auto .35rem .18rem 1.1rem;
    block-size: 1px;
  }

  .codex-article-view-switcher[data-era-style='e4'] .codex-article-view-tab[aria-selected='true'] {
    transform: translate(.14rem, -.12rem);
    filter: drop-shadow(-.24rem .24rem 0 color-mix(in oklch, var(--view-tab-accent) 26%, transparent));
  }

  .codex-storyteller-panel {
    max-width: 52rem;
    padding-block-start: 1.5rem;
  }

  .codex-storyteller-intro {
    margin-block-end: 2rem;
    padding: 1rem 1.1rem;
    border-inline-start: 2px solid var(--sl-color-accent-high);
    background: color-mix(in oklch, var(--codex-accent) 7%, transparent);
  }

  .codex-storyteller-intro p {
    margin: 0;
  }

  .codex-storyteller-intro .codex-kicker {
    margin-block-end: .25rem;
    font-size: var(--sl-text-xs);
    font-weight: 700;
    letter-spacing: .09em;
    text-transform: uppercase;
  }

  .codex-storyteller-section + .codex-storyteller-section {
    margin-block-start: 2rem;
  }

  .codex-storyteller-section h2 {
    margin: 0 0 .75rem;
    color: var(--sl-color-white);
    font-size: var(--sl-text-h3);
  }

  .codex-storyteller-facts {
    margin: 0;
  }

  .codex-storyteller-fact {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: .25rem;
    padding-block: .8rem;
    border-block-start: 1px solid var(--sl-color-hairline-light);
  }

  .codex-storyteller-fact:last-child {
    border-block-end: 1px solid var(--sl-color-hairline-light);
  }

  .codex-storyteller-fact dt {
    color: var(--sl-color-gray-3);
    font-size: var(--sl-text-sm);
    font-weight: 650;
  }

  .codex-storyteller-fact dd {
    margin: 0;
    color: var(--sl-color-gray-1);
    line-height: 1.65;
  }

  .codex-storyteller-value {
    display: block;
  }

  html[data-codex-article-view='storyteller'] .right-sidebar-container {
    display: none !important;
  }

  @media (max-width: 31rem) {
    .codex-article-view-tabs {
      inline-size: 100%;
    }

    .codex-article-view-tab,
    .codex-article-view-switcher[data-era-style] .codex-article-view-tab {
      min-inline-size: 0;
      flex: 1 1 50%;
      padding-inline: 1rem;
    }

    .codex-article-view-switcher[data-era-style='e1'] .codex-article-view-tab + .codex-article-view-tab {
      margin-inline-start: -.4rem;
    }
  }

  @media (min-width: 42rem) {
    .codex-storyteller-fact {
      grid-template-columns: minmax(10rem, 13rem) minmax(0, 1fr);
      gap: 1.25rem;
    }
  }

  @media (min-width: 72rem) {
    html[data-codex-article-view='storyteller'] .main-frame > .codex-two-column-content > .codex-main-pane:has(> .right-sidebar-container) {
      grid-template-columns: minmax(0, 1fr) !important;
    }

    html[data-codex-article-view='storyteller'] .main-frame > .codex-two-column-content > .codex-main-pane:has(> .right-sidebar-container) > main > .content-panel > .sl-container {
      max-width: min(100%, 52rem) !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .codex-article-view-tab {
      transition: none;
    }
  }

  @media (forced-colors: active) {
    .codex-article-view-tabs {
      border-block-end: 1px solid CanvasText;
    }

    .codex-article-view-tab,
    .codex-article-view-switcher[data-era-style] .codex-article-view-tab {
      clip-path: none;
      border: 1px solid ButtonText;
      background: ButtonFace;
      color: ButtonText;
      filter: none;
      transform: none;
    }

    .codex-article-view-tab[aria-selected='true'] {
      border-block-end-width: 3px;
    }
  }
</style>