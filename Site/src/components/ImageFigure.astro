---
const {
  src,
  alt = '',
  credit = '',
  caption = '',
  id,
  href = '',
  detailHref = '',
  imagePage = '',
  title = '',
  artist = '',
} = Astro.props;
const finalSrc = src ?? (id ? `/assets/images/${id}.webp` : '');
const imageHref = detailHref || imagePage || href;
const creditText = artist || credit;
const label = title || caption || alt || 'Image details';
---
<figure class="image-figure">
  {finalSrc ? (
    imageHref ? (
      <a class="image-figure-link" href={imageHref} aria-label={`Open image details for ${label}`}>
        <img src={finalSrc} alt={alt} loading="lazy" />
      </a>
    ) : (
      <img src={finalSrc} alt={alt} loading="lazy" />
    )
  ) : <p class="codex-warning">Image source missing.</p>}
  {(caption || title || creditText) && (
    <figcaption>
      {caption || title}
      {creditText && <span> Credit: {creditText}</span>}
    </figcaption>
  )}
</figure>