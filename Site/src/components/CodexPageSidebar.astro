---
import MobileTableOfContents from 'virtual:starlight/components/MobileTableOfContents';
import TableOfContents from 'virtual:starlight/components/TableOfContents';
import CodexBacklinks from './CodexBacklinks.astro';
import CodexMiniGraph from './CodexMiniGraph.astro';

const { starlightRoute } = Astro.locals;
const entry = starlightRoute.entry.data;

function isPresent(value) {
  return value !== undefined && value !== null && value !== '' && (!Array.isArray(value) || value.length > 0);
}

function isExternalUrl(value) {
  return typeof value === 'string' && /^[a-z][a-z0-9+.-]*:/i.test(value);
}

function normaliseAssetPath(value, category = 'images') {
  if (typeof value !== 'string') return undefined;
  const trimmed = value.trim();
  if (!trimmed) return undefined;
  if (trimmed.startsWith('/') || isExternalUrl(trimmed)) return trimmed;
  return `/assets/${category}/${trimmed.split('/').pop()}`;
}

function normaliseRoute(value) {
  if (typeof value !== 'string') return undefined;
  const trimmed = value.trim();
  if (!trimmed) return undefined;
  if (trimmed.startsWith('/') || trimmed.startsWith('#') || isExternalUrl(trimmed)) return trimmed;
  return `/${trimmed.replace(/^\/+|\/+$/g, '')}/`;
}

function formatValue(value) {
  return Array.isArray(value) ? value.join(', ') : String(value).replace(/-/g, ' ');
}

const rawImageSource = entry.image ?? (entry.type === 'image' ? entry.asset : undefined);
const sidebarImage = normaliseAssetPath(rawImageSource);
const imageDetailHref = normaliseRoute(entry.imagePage);
const imageAlt = entry.alt ?? `${entry.title} image`;
const artworkTitle = entry.imageTitle ?? (entry.type === 'image' ? entry.title : undefined);
const artworkArtist = entry.artist ?? entry.credit;
const resolution = entry.width && entry.height ? `${entry.width} × ${entry.height}` : undefined;
const sidebarFields = [
  ['Type', entry.type],
  ['Status', entry.status],
  ['Era', entry.era],
  ['Faction', entry.faction],
  ['Location', entry.location],
  ['Character', entry.character],
  ['Tags', entry.tags],
  ['Artwork', entry.imageTitle],
  ['Artist', entry.artist],
  ['Editor', entry.editor],
  ['Source', entry.source],
  ['Source URL', entry.sourceUrl],
  ['Credit', entry.artist ? undefined : entry.credit],
  ['License', entry.license],
  ['Rights', entry.rights],
  ['Usage', entry.usage],
  ['Resolution', resolution],
].filter(([, value]) => isPresent(value));
---

{
  starlightRoute.toc && (
    <>
      <div class="lg:sl-hidden">
        <MobileTableOfContents />
      </div>
      <aside class="right-sidebar-panel codex-page-sidebar sl-hidden lg:sl-block" aria-label="Page sidebar">
        <div class="sl-container">
          <section class="codex-sidebar-card" aria-labelledby="codex-sidebar-title">
            {sidebarImage && (
              <div class="codex-sidebar-artwork">
                {imageDetailHref ? (
                  <a class="codex-sidebar-image-link" href={imageDetailHref} aria-label={`Open image details for ${artworkTitle ?? entry.title}`}>
                    <img class="codex-sidebar-image" src={sidebarImage} alt={imageAlt} loading="lazy" decoding="async" />
                  </a>
                ) : (
                  <img class="codex-sidebar-image" src={sidebarImage} alt={imageAlt} loading="lazy" decoding="async" />
                )}
                {(artworkTitle || artworkArtist) && (
                  <div class="codex-sidebar-art-caption">
                    {artworkTitle && <p class="codex-sidebar-art-title">{artworkTitle}</p>}
                    {artworkArtist && <p class="codex-sidebar-art-artist">by {artworkArtist}</p>}
                  </div>
                )}
              </div>
            )}
            <div class="codex-sidebar-body">
              <p class="codex-sidebar-kicker">{entry.type ?? 'Entry'}</p>
              <h2 id="codex-sidebar-title">{entry.title}</h2>
              {entry.description && <p class="codex-sidebar-description">{entry.description}</p>}
              {sidebarFields.length > 0 && (
                <dl class="codex-sidebar-meta">
                  {sidebarFields.map(([label, value]) => (
                    <div>
                      <dt>{label}</dt>
                      <dd>{isExternalUrl(value) ? <a href={value} target="_blank" rel="noreferrer">Open source</a> : formatValue(value)}</dd>
                    </div>
                  ))}
                </dl>
              )}
            </div>
          </section>
          <TableOfContents />
          <section class="codex-sidebar-section" aria-labelledby="codex-sidebar-graph-title">
            <h2 id="codex-sidebar-graph-title">Graph View</h2>
            <CodexMiniGraph />
          </section>
          <section class="codex-sidebar-section" aria-labelledby="codex-sidebar-backlinks-title">
            <h2 id="codex-sidebar-backlinks-title">Backlinks</h2>
            <CodexBacklinks />
          </section>
        </div>
      </aside>
    </>
  )
}

<style>
  @layer starlight.core {
    .right-sidebar-panel {
      box-sizing: border-box;
      width: 100%;
      max-width: none;
      min-width: 0;
      padding: 1rem 0;
    }

    .sl-container {
      box-sizing: border-box;
      display: grid;
      gap: 1rem;
      width: 100%;
      max-width: none;
      min-width: 0;
      margin-inline: 0;
      padding-inline: 0;
    }

    .codex-sidebar-card,
    .codex-sidebar-section,
    :global(starlight-toc nav) {
      width: 100%;
      min-width: 0;
    }

    .codex-sidebar-section {
      margin-top: 1.5rem;
    }

    .right-sidebar-panel :global(h2) {
      color: var(--sl-color-white);
      font-size: var(--sl-text-h5);
      font-weight: 600;
      line-height: var(--sl-line-height-headings);
      margin-bottom: 0.5rem;
    }

    .right-sidebar-panel :global(:where(a)) {
      display: block;
      font-size: var(--sl-text-xs);
      text-decoration: none;
      color: var(--sl-color-gray-3);
      overflow-wrap: anywhere;
    }

    .right-sidebar-panel :global(:where(a):hover) {
      color: var(--sl-color-white);
    }
  }
</style>
