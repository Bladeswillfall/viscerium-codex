---
import { getCalendar } from '../../lib/calendar/registry';
import { getCalendarYearDates, isLeapYear, resolveCalendarDate } from '../../lib/calendar/convert';
import type { CalendarEventLink, CalendarEventLinks, CalendarObservance, ResolvedCalendarDate } from '../../lib/calendar/types';

interface Props {
  calendarId?: string;
  year?: number;
  eventLinks?: CalendarEventLinks;
}

const { calendarId = 'okse', eventLinks = {} } = Astro.props as Props;
const calendar = getCalendar(calendarId);
const year = (Astro.props as Props).year ?? calendar.defaultYear;
const dates = getCalendarYearDates(calendar.id, year);
const datesByAnchor = new Map(dates.map((date) => [date.anchor, date]));
const seasonLabels = ['winter', 'spring', 'summer', 'autumn'];
const daysPerWeek = 7;
const intercalaryColumns = 2;

function getDateForMonthDay(month: string, day: number) {
  return datesByAnchor.get(`${month}-${String(day).padStart(2, '0')}`);
}

function getDateForIntercalary(slug: string) {
  return datesByAnchor.get(slug);
}

function routeLike(value: string): string {
  const trimmed = value.trim();
  if (!trimmed) return '#';
  if (/^(https?:|mailto:|#|\/)/i.test(trimmed)) return trimmed;
  return `/${trimmed.replace(/^\/+|\/+$/g, '')}/`;
}

function resolveLinkValue(link?: CalendarEventLink): { href?: string; label?: string } {
  if (!link) return {};
  if (typeof link === 'string') return { href: routeLike(link) };
  return {
    href: link.href ? routeLike(link.href) : link.article ? routeLike(link.article) : undefined,
    label: link.label,
  };
}

function getObservanceLink(observance: CalendarObservance) {
  return resolveLinkValue(eventLinks[observance.slug] ?? observance.href ?? observance.article);
}

function getLinkedObservances(resolved: ResolvedCalendarDate) {
  return resolved.observances
    .map((observance) => ({ observance, link: getObservanceLink(observance) }))
    .filter((item) => Boolean(item.link.href));
}

function getCellMeta(resolved: ResolvedCalendarDate) {
  const linkedObservances = getLinkedObservances(resolved);
  const primaryLinkedObservance = linkedObservances[0];
  const observanceNames = resolved.observances.map((observance) => observance.name);
  const targetLabel = primaryLinkedObservance?.link.label ?? primaryLinkedObservance?.observance.name;
  const title = [resolved.label, ...observanceNames].join(' — ');

  return {
    href: primaryLinkedObservance?.link.href ?? `#${resolved.anchor}`,
    hasLinkedEvent: Boolean(primaryLinkedObservance?.link.href),
    title: targetLabel ? `${title} — open ${targetLabel}` : title,
    ariaLabel: targetLabel ? `${resolved.label}; open ${targetLabel}` : resolved.label,
    eventNames: observanceNames,
  };
}
---

<section class="calendar-module" aria-labelledby="calendar-module-title">
  <div class="calendar-module__intro">
    <div class="calendar-module__summary">
      <p class="codex-kicker">World-time calendar</p>
      <h2 id="calendar-module-title">{calendar.name}</h2>
      {calendar.description && <p>{calendar.description}</p>}
    </div>
    <dl class="calendar-module__facts codex-frame">
      <div class="calendar-module__fact">
        <dt>Rendered year</dt>
        <dd>{year}</dd>
      </div>
      <div class="calendar-module__fact">
        <dt>Leap rule</dt>
        <dd>{calendar.leapRule?.label ?? 'No leap years'}</dd>
      </div>
      <div class="calendar-module__fact">
        <dt>Leap year?</dt>
        <dd>{isLeapYear(calendar, year) ? 'Yes' : 'No'}</dd>
      </div>
    </dl>
  </div>

  <div class="calendar-year-grid">
    {calendar.months.map((month) => (
      <section class="calendar-month" aria-labelledby={`calendar-${month.slug}`}>
        <h3 id={`calendar-${month.slug}`}>{month.name} <span>({month.ordinal})</span></h3>
        <table class="calendar-days calendar-days--month" aria-label={`${month.name} days`}>
          <tbody>
            {Array.from({ length: Math.ceil(month.days / daysPerWeek) }, (_, weekIndex) => (
              <tr class="calendar-week">
                {Array.from({ length: daysPerWeek }, (_, weekdayIndex) => {
                  const day = weekIndex * daysPerWeek + weekdayIndex + 1;
                  if (day > month.days) {
                    return <td class="calendar-day calendar-day--empty" aria-hidden="true"></td>;
                  }

                  const resolved = getDateForMonthDay(month.slug, day) ?? resolveCalendarDate({ calendar: calendar.id, year, month: month.slug, day });
                  const hasHoliday = resolved.observances.some((observance) => observance.type === 'holiday');
                  const hasSeasonMarker = resolved.observances.some((observance) => observance.type !== 'holiday');
                  const meta = getCellMeta(resolved);

                  return (
                    <td
                      id={resolved.anchor}
                      class:list={[
                        'calendar-day',
                        `calendar-day--${resolved.season}`,
                        hasHoliday && 'calendar-day--holiday',
                        hasSeasonMarker && 'calendar-day--marker',
                        meta.hasLinkedEvent && 'calendar-day--linked-event',
                      ]}
                    >
                      <a href={meta.href} aria-label={meta.ariaLabel} title={meta.title}>
                        <span class="calendar-day__number">{day}</span>
                        <span class="calendar-day__weekday">{resolved.weekday}</span>
                        {meta.eventNames.length > 0 && (
                          <span class="calendar-day__events">{meta.eventNames.join(', ')}</span>
                        )}
                      </a>
                    </td>
                  );
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    ))}

    <section class="calendar-month calendar-month--intercalary" aria-labelledby="calendar-engimanutur">
      <h3 id="calendar-engimanutur">Engimanutur <span>(0th/14th)</span></h3>
      <table class="calendar-days calendar-days--intercalary" aria-label="Engimanutur days">
        <tbody>
          {Array.from({ length: Math.ceil(calendar.intercalaryDays.length / intercalaryColumns) }, (_, rowIndex) => (
            <tr class="calendar-week">
              {Array.from({ length: intercalaryColumns }, (_, columnIndex) => {
                const intercalaryDay = calendar.intercalaryDays[rowIndex * intercalaryColumns + columnIndex];
                if (!intercalaryDay) {
                  return <td class="calendar-day calendar-day--empty" aria-hidden="true"></td>;
                }

                const resolved = getDateForIntercalary(intercalaryDay.slug);
                const visible = Boolean(resolved);
                const meta = resolved ? getCellMeta(resolved) : undefined;

                return (
                  <td
                    id={intercalaryDay.slug}
                    class:list={[
                      'calendar-day',
                      'calendar-day--intercalary',
                      `calendar-day--${intercalaryDay.season}`,
                      intercalaryDay.leapOnly && 'calendar-day--leap',
                      resolved?.observances.some((observance) => observance.type !== 'holiday') && 'calendar-day--marker',
                      meta?.hasLinkedEvent && 'calendar-day--linked-event',
                      !visible && 'calendar-day--inactive',
                    ]}
                  >
                    {resolved && meta ? (
                      <a href={meta.href} aria-label={meta.ariaLabel} title={meta.title}>
                        <span class="calendar-day__number">{String(intercalaryDay.day).padStart(2, '0')}</span>
                        <span class="calendar-day__weekday">{resolved.weekday}</span>
                        {meta.eventNames.length > 0 && (
                          <span class="calendar-day__events">{meta.eventNames.join(', ')}</span>
                        )}
                      </a>
                    ) : (
                      <span aria-label={`${intercalaryDay.name} ${intercalaryDay.day} only exists in leap years`}>
                        <span class="calendar-day__number">{String(intercalaryDay.day).padStart(2, '0')}</span>
                        <span class="calendar-day__weekday">Leap only</span>
                      </span>
                    )}
                  </td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="calendar-legend codex-frame" aria-labelledby="calendar-legend-title">
      <h3 id="calendar-legend-title">Key</h3>
      <dl>
        {seasonLabels.map((season) => (
          <div>
            <dt><span class={`calendar-key calendar-key--${season}`}></span>{season}</dt>
            <dd>Season band</dd>
          </div>
        ))}
        <div>
          <dt><span class="calendar-key calendar-key--leap"></span>Leap day</dt>
          <dd>Only appears in leap years</dd>
        </div>
        <div>
          <dt><span class="calendar-key calendar-key--holiday"></span>Holiday</dt>
          <dd>Marked observance</dd>
        </div>
        <div>
          <dt><span class="calendar-key calendar-key--marker"></span>Red number</dt>
          <dd>Solstice, equinox, or seasonal marker</dd>
        </div>
        <div>
          <dt><span class="calendar-key calendar-key--linked"></span>Linked event</dt>
          <dd>Opens an event article</dd>
        </div>
      </dl>
    </section>
  </div>
</section>

<style is:global>
  @layer starlight.core {
    @media (max-width: 95rem) {
      .calendar-module .calendar-module__intro {
        grid-template-columns: minmax(0, 1fr) !important;
      }

      .calendar-module .calendar-module__summary,
      .calendar-module .calendar-module__facts {
        grid-column: 1 / -1 !important;
        min-width: 0 !important;
        inline-size: auto !important;
        max-inline-size: none !important;
      }

      .calendar-module .calendar-module__summary *,
      .calendar-module .calendar-module__facts * {
        overflow-wrap: normal !important;
        word-break: normal !important;
        hyphens: manual !important;
      }
    }

    @media (min-width: 95.001rem) {
      .calendar-module .calendar-module__intro {
        grid-template-columns: minmax(24rem, 1fr) minmax(18rem, 24rem) !important;
      }
    }
  }
</style>
