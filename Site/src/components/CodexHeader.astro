---
import config from 'virtual:starlight/user-config';

import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import CodexThemeToggle from './CodexThemeToggle.astro';

/**
 * Keep Starlight's native Pagefind control visible whenever Pagefind is enabled.
 * The override check preserves compatibility with any future custom Search component.
 */
const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';
---

<div class="header codex-header">
  <div class="title-wrapper sl-flex">
    <SiteTitle />
  </div>

  <div class="codex-header-search print:hidden" data-codex-header-search>
    {shouldRenderSearch && <Search />}
  </div>

  <!--
    Starlight Telescope injects its custom element into `.right-group` at runtime.
    Keep this class stable: it is part of the plugin integration contract.
  -->
  <div class="right-group codex-header-controls print:hidden" data-codex-header-controls>
    <div class="social-icons sl-flex">
      <SocialIcons />
    </div>
    <CodexThemeToggle />
    <LanguageSelect />
  </div>
</div>

<style is:global>
  @layer starlight.core {
    .codex-header {
      display: grid;
      grid-template-columns: minmax(0, auto) minmax(2.5rem, 1fr) auto;
      gap: .5rem;
      align-items: center;
      width: 100%;
      height: 100%;
    }

    .codex-header .title-wrapper {
      min-width: 0;
      max-width: min(42vw, 18rem);
      overflow: clip;
      padding: .25rem;
      margin: -.25rem;
    }

    .codex-header-search {
      display: flex;
      min-width: 0;
      justify-content: flex-end;
    }

    .codex-header-search button[data-open-modal] {
      width: 2.5rem;
      min-width: 2.5rem;
      height: 2.5rem;
      justify-content: center;
      border: 1px solid var(--sl-color-gray-5);
      border-radius: 0;
      padding: 0;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, .025), transparent),
        var(--sl-color-black);
      color: var(--sl-color-gray-2);
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, .012);
    }

    .codex-header-search button[data-open-modal]:hover {
      border-color: var(--sl-color-gray-2);
      background:
        linear-gradient(180deg, rgba(184, 135, 70, .09), transparent),
        var(--sl-color-black);
      color: var(--sl-color-white);
    }

    .codex-header-controls {
      display: flex;
      min-width: max-content;
      flex: 0 0 auto;
      gap: .4rem;
      align-items: center;
    }

    .codex-header .social-icons {
      display: none;
      gap: .65rem;
      align-items: center;
    }

    .codex-header .social-icons::after {
      content: '';
      height: 2rem;
      border-inline-end: 1px solid var(--sl-color-gray-5);
    }

    .codex-header telescope-search {
      display: inline-flex;
    }

    .codex-header .telescope__trigger-btn {
      display: inline-flex;
      min-width: 2.5rem;
      height: 2.5rem;
      align-items: center;
      justify-content: center;
      gap: .5rem;
      border: 1px solid var(--sl-color-gray-5);
      border-radius: 0;
      padding: 0 .65rem;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, .025), transparent),
        var(--sl-color-black);
      color: var(--sl-color-gray-2);
      cursor: pointer;
    }

    .codex-header .telescope__trigger-btn:hover {
      border-color: var(--sl-color-gray-2);
      background:
        linear-gradient(180deg, rgba(184, 135, 70, .09), transparent),
        var(--sl-color-black);
      color: var(--sl-color-white);
    }

    .codex-header .telescope__trigger-btn:focus-visible,
    .codex-header-search button[data-open-modal]:focus-visible {
      outline: 2px solid var(--sl-color-accent-high);
      outline-offset: 2px;
    }

    @media (min-width: 50rem) {
      .codex-header {
        grid-template-columns: minmax(12rem, 1fr) minmax(16rem, 34rem) auto;
        gap: 1rem;
      }

      .codex-header .title-wrapper {
        max-width: none;
      }

      .codex-header-search {
        width: 100%;
        justify-content: center;
      }

      .codex-header-search site-search {
        display: contents;
      }

      .codex-header-search button[data-open-modal] {
        width: 100%;
        max-width: none;
        min-width: 14rem;
        justify-content: flex-start;
        padding-inline: .85rem .65rem;
      }

      .codex-header-search button[data-open-modal] > :last-child {
        margin-inline-start: auto;
      }

      .codex-header .social-icons {
        display: flex;
      }
    }
  }

  /*
    Starlight's responsive utility classes currently collapse the native Search button back
    to its mobile icon-only width after the Ion layer has rendered. Keep this critical header
    geometry unlayered so the desktop field cannot be silently reduced by future upgrades.
  */
  @media (min-width: 50rem) {
    .codex-header-search {
      width: 100% !important;
      min-width: 14rem !important;
    }

    .codex-header-search button[data-open-modal] {
      display: flex !important;
      width: 100% !important;
      max-width: none !important;
      min-width: 14rem !important;
      justify-content: flex-start !important;
      padding-inline: .85rem .65rem !important;
    }

    .codex-header-search button[data-open-modal] > span {
      display: block !important;
    }

    .codex-header-search button[data-open-modal] > kbd {
      display: flex !important;
      margin-inline-start: auto !important;
    }
  }
</style>
