---
import config from 'virtual:starlight/user-config';

import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import CodexThemeToggle from './CodexThemeToggle.astro';

/**
 * Keep Starlight's native Pagefind control visible whenever Pagefind is enabled.
 * The override check preserves compatibility with any future custom Search component.
 */
const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';
---

<div class="header codex-header">
  <div class="title-wrapper sl-flex">
    <SiteTitle />
  </div>

  <div class="codex-header-search print:hidden" data-codex-header-search>
    {shouldRenderSearch && <Search />}
  </div>

  <!--
    Starlight Telescope injects its custom element into `.right-group` at runtime.
    Keep this class stable: it is part of the plugin integration contract.
  -->
  <div class="right-group codex-header-controls print:hidden" data-codex-header-controls>
    <div class="social-icons sl-flex">
      <SocialIcons />
    </div>
    <CodexThemeToggle />
    <LanguageSelect />
  </div>
</div>
