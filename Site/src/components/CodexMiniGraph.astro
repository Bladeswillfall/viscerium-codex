---
import graph from '../data/graph.json';

const { starlightRoute } = Astro.locals;
const entry = starlightRoute.entry.data;
const currentId = String(entry.slug ?? starlightRoute.entry.id)
  .replace(/\.(md|mdx)$/, '')
  .replace(/^\/+|\/+$/g, '');
const nodeById = new Map(graph.nodes.map((node) => [node.id, node]));
const currentNode = nodeById.get(currentId) ?? {
  id: currentId,
  title: entry.title,
  type: entry.type ?? 'article',
};

const connectedEdges = graph.edges.filter((edge) => edge.source === currentId || edge.target === currentId);
const allNeighbourIds = [
  ...new Set(connectedEdges.map((edge) => (edge.source === currentId ? edge.target : edge.source))),
].filter((id) => nodeById.has(id));
const neighbourIds = allNeighbourIds.slice(0, 8);
const hiddenNeighbourCount = Math.max(0, allNeighbourIds.length - neighbourIds.length);
const nodes = [currentNode, ...neighbourIds.map((id) => nodeById.get(id)).filter(Boolean)];

const width = 300;
const height = 220;
const center = { x: width / 2, y: 98 };
const radius = 72;

const positionedNodes = nodes.map((node, index) => {
  if (index === 0) return { node, x: center.x, y: center.y, current: true };
  const angle = -Math.PI / 2 + ((index - 1) / Math.max(1, nodes.length - 1)) * Math.PI * 2;
  return {
    node,
    x: center.x + Math.cos(angle) * radius,
    y: center.y + Math.sin(angle) * radius,
    current: false,
  };
});

const positionById = new Map(positionedNodes.map((item) => [item.node.id, item]));
const visibleEdges = connectedEdges.filter((edge) => positionById.has(edge.source) && positionById.has(edge.target));

function routeFor(id) {
  return id === 'index' ? '/' : `/${id}/`;
}

function labelFor(title) {
  const text = String(title ?? '').trim();
  return text.length > 18 ? `${text.slice(0, 16)}…` : text;
}

function diamondPoints(x, y, size) {
  return `${x},${y - size} ${x + size},${y} ${x},${y + size} ${x - size},${y}`;
}
---

<div class="codex-mini-graph" data-node-count={nodes.length}>
  {nodes.length > 1 ? (
    <>
      <svg class="codex-mini-graph__svg" viewBox={`0 0 ${width} ${height}`} role="img" aria-label={`Graph connections for ${currentNode.title}`}>
        <g class="codex-mini-graph__edges" aria-hidden="true">
          {visibleEdges.map((edge) => {
            const source = positionById.get(edge.source);
            const target = positionById.get(edge.target);
            return source && target ? (
              <line
                x1={source.x}
                y1={source.y}
                x2={target.x}
                y2={target.y}
                class={edge.source === currentId ? 'is-outgoing' : 'is-incoming'}
              />
            ) : null;
          })}
        </g>
        <g class="codex-mini-graph__nodes">
          {positionedNodes.map(({ node, x, y, current }) => (
            <a href={routeFor(node.id)} class={current ? 'codex-mini-graph__node is-current' : 'codex-mini-graph__node'}>
              <polygon points={diamondPoints(x, y, current ? 10 : 7)} />
              <title>{node.title}</title>
            </a>
          ))}
        </g>
        <g class="codex-mini-graph__labels" aria-hidden="true">
          {positionedNodes.map(({ node, x, y, current }) => (
            <text x={x} y={y + (current ? 25 : 20)} text-anchor="middle" class={current ? 'is-current' : undefined}>
              {labelFor(node.title)}
            </text>
          ))}
        </g>
      </svg>
      {hiddenNeighbourCount > 0 && <p class="codex-mini-graph__note">+{hiddenNeighbourCount} more connected entries.</p>}
    </>
  ) : (
    <p class="codex-empty-state">No public graph links yet.</p>
  )}
</div>
