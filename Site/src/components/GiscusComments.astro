---
const repo = import.meta.env.PUBLIC_GISCUS_REPO;
const repoId = import.meta.env.PUBLIC_GISCUS_REPO_ID;
const category = import.meta.env.PUBLIC_GISCUS_CATEGORY;
const categoryId = import.meta.env.PUBLIC_GISCUS_CATEGORY_ID;
const enabled = Boolean(repo && repoId && category && categoryId);
---
<section class="codex-comments" aria-labelledby="codex-comments-title">
  <details>
    <summary id="codex-comments-title">
      <span>Page comments</span>
      <span class="codex-comments-hint">GitHub Discussions via giscus</span>
    </summary>
    <div class="codex-comments-panel">
      {enabled ? (
        <script
          src="https://giscus.app/client.js"
          data-repo={repo}
          data-repo-id={repoId}
          data-category={category}
          data-category-id={categoryId}
          data-mapping="pathname"
          data-strict="0"
          data-reactions-enabled="1"
          data-emit-metadata="0"
          data-input-position="bottom"
          data-theme="preferred_color_scheme"
          data-lang="en"
          crossorigin="anonymous"
          async>
        </script>
      ) : (
        <div class="codex-warning">
          <p><strong>Comments are ready but not enabled yet.</strong></p>
          <p>Set the public giscus environment variables documented in the README to show GitHub Discussions comments here.</p>
        </div>
      )}
    </div>
  </details>
</section>
