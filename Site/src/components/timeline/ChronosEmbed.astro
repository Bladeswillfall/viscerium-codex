---
const {
  source = '',
  compact = false,
  label = 'Interactive Chronos timeline',
} = Astro.props;

const serializedSource = JSON.stringify(String(source)).replace(/</g, '\\u003c');
const serializedOptions = JSON.stringify({ compact, label }).replace(/</g, '\\u003c');
---

<div class="vc-chronos-embed" data-vc-chronos-root>
  <div class="vc-chronos-embed-canvas" data-vc-chronos-mount aria-label={label}></div>
  <div class="vc-chronos-source-fallback" data-vc-chronos-fallback>
    <p>Interactive timeline source:</p>
    <pre><code>{source}</code></pre>
  </div>
  <script type="application/json" data-vc-chronos-source set:html={serializedSource}></script>
  <script type="application/json" data-vc-chronos-options set:html={serializedOptions}></script>
</div>

<script>
  import 'vis-timeline/styles/vis-timeline-graph2d.min.css';
  import '../../styles/chronos.css';
  import { ChronosTimeline } from 'chronos-timeline-md';

  const chronosInstances = new WeakMap<Element, ChronosTimeline>();

  function mountChronosEmbeds() {
    for (const root of document.querySelectorAll('[data-vc-chronos-root]:not([data-vc-chronos-mounted])')) {
      root.setAttribute('data-vc-chronos-mounted', 'true');
      try {
        const source = JSON.parse(root.querySelector('[data-vc-chronos-source]')?.textContent || '""');
        const options = JSON.parse(root.querySelector('[data-vc-chronos-options]')?.textContent || '{}');
        const mount = root.querySelector<HTMLElement>('[data-vc-chronos-mount]');
        if (!mount) throw new Error('Chronos mount element is missing.');

        const chronos = new ChronosTimeline({
          container: mount,
          settings: {
            selectedLocale: 'en',
            align: 'left',
            clickToUse: false,
            roundRanges: true,
            useUtc: true,
            useAI: false,
            theme: {
              customClass: 'vc-chronos-core',
            },
          },
          callbacks: {
            setTooltip: (element, text) => element.setAttribute('title', text),
          },
          cssRootClass: 'vc-chronos-core',
        });

        chronos.render(source);
        chronos.timeline?.setOptions({
          minHeight: options.compact ? '14rem' : '20rem',
          horizontalScroll: true,
          zoomKey: 'ctrlKey',
          selectable: true,
          tooltip: { followMouse: true, overflowMethod: 'cap' },
        });
        root.querySelector('[data-vc-chronos-fallback]')?.setAttribute('hidden', '');
        chronosInstances.set(root, chronos);
      } catch (error) {
        console.error('Chronos Markdown timeline failed to mount.', error);
        root.removeAttribute('data-vc-chronos-mounted');
      }
    }
  }

  mountChronosEmbeds();
  document.addEventListener('astro:page-load', mountChronosEmbeds);
  document.addEventListener('astro:before-swap', () => {
    for (const root of document.querySelectorAll('[data-vc-chronos-root]')) {
      chronosInstances.get(root)?.destroy();
      chronosInstances.delete(root);
    }
  });
</script>
