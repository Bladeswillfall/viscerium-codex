---
interface Props {
  text: string;
  href?: string;
  label?: string;
  external?: boolean;
  class?: string;
  id?: string;
}

const {
  text,
  href,
  label,
  external = Boolean(href && /^https?:\/\//i.test(href)),
  class: className,
  id,
} = Astro.props;
const tooltipId = id ?? `codex-tooltip-${crypto.randomUUID().replace(/-/g, '')}`;
const Trigger = href ? 'a' : 'span';
---

<span class="codex-tooltip">
  <Trigger
    class:list={['codex-tooltip__trigger', className]}
    href={href}
    target={external ? '_blank' : undefined}
    rel={external ? 'noreferrer' : undefined}
    tabindex={href ? undefined : '0'}
    aria-label={label}
    aria-describedby={tooltipId}
  >
    <slot />
  </Trigger>
  <span id={tooltipId} class="codex-tooltip__bubble" role="tooltip">{text}</span>
</span>

<style>
  .codex-tooltip {
    position: relative;
    display: inline-flex;
  }

  .codex-tooltip__trigger {
    display: inline-flex;
    align-items: center;
  }

  .codex-tooltip__bubble {
    position: absolute;
    z-index: 80;
    inset-block-end: calc(100% + 0.55rem);
    inset-inline-start: 50%;
    width: max-content;
    max-width: min(22rem, 80vw);
    padding: 0.45rem 0.6rem;
    border: 1px solid var(--sl-color-hairline-light);
    background: var(--sl-color-bg-nav);
    color: var(--sl-color-white);
    box-shadow: 0 0.45rem 1.25rem rgb(0 0 0 / 28%);
    font-family: var(--sl-font-system);
    font-size: var(--sl-text-xs);
    font-weight: 500;
    line-height: 1.35;
    text-align: center;
    white-space: normal;
    opacity: 0;
    pointer-events: none;
    transform: translate(-50%, 0.3rem);
    transition: opacity 140ms ease, transform 140ms ease;
  }

  .codex-tooltip__bubble::after {
    content: '';
    position: absolute;
    inset-block-start: 100%;
    inset-inline-start: 50%;
    width: 0.55rem;
    height: 0.55rem;
    border-inline-end: 1px solid var(--sl-color-hairline-light);
    border-block-end: 1px solid var(--sl-color-hairline-light);
    background: var(--sl-color-bg-nav);
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .codex-tooltip:hover .codex-tooltip__bubble,
  .codex-tooltip:focus-within .codex-tooltip__bubble {
    opacity: 1;
    transform: translate(-50%, 0);
  }

  @media (prefers-reduced-motion: reduce) {
    .codex-tooltip__bubble {
      transition: none;
    }
  }
</style>
