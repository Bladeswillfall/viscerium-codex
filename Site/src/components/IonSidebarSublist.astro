---
import { Badge } from '@astrojs/starlight/components';
import { parseIconLabel } from '../lib/icon-spec.mjs';
import LocalIcon from './LocalIcon.astro';

interface Props {
  sublist: any[];
  nested?: boolean;
}

const { sublist, nested = false } = Astro.props;
---

<ul class:list={{ 'top-level': !nested }}>
  {sublist.map((entry) => {
    const { icon, label } = parseIconLabel(entry.label);
    const { class: entryClass, ...attrs } = entry.attrs ?? {};

    return (
      <li class:list={{ active: entry.type === 'link' && entry.isCurrent, 'has-icon': icon }}>
        {entry.type === 'link' ? (
          <a
            href={entry.href}
            aria-current={entry.isCurrent ? 'page' : undefined}
            class:list={['flex-link', { individual: !nested }, entryClass]}
            {...attrs}
          >
            {icon && <LocalIcon name={icon} />}
            <span>{label}</span>
            {entry.badge && <Badge text={entry.badge.text} variant={entry.badge.variant} />}
          </a>
        ) : (
          <details
            class="ion-expandable-group"
            open={!entry.collapsed || entry.entries?.some((item: any) => item.isCurrent)}
          >
            <summary>
              <span class="group-label">
                {icon && <LocalIcon name={icon} />}
                <span class="large">{label}</span>
                {entry.badge && <Badge text={entry.badge.text} variant={entry.badge.variant} />}
                <span class="caret" aria-hidden="true">›</span>
              </span>
            </summary>
            <Astro.self sublist={entry.entries} nested />
          </details>
        )}
      </li>
    );
  })}
</ul>

<style>
  @layer starlight.core {
    ul {
      margin: 0;
      padding: 0;
      list-style: none;
      color: var(--sl-color-gray-2);
    }

    li {
      margin-block-end: .25rem;
      overflow-wrap: anywhere;
    }

    ul ul {
      margin-inline-start: .5rem;
      padding-inline-start: .5rem;
    }

    .top-level > li + li {
      margin-block-start: .5rem;
    }

    summary,
    a {
      padding: .3em var(--sl-sidebar-item-padding-inline);
      color: inherit;
      line-height: 1.4;
    }

    summary {
      display: block;
      cursor: pointer;
      user-select: none;
    }

    summary::marker,
    summary::-webkit-details-marker {
      display: none;
    }

    a {
      display: block;
      text-decoration: none;
    }

    a:hover,
    a:focus-visible {
      color: var(--sl-color-white);
    }

    .group-label,
    .flex-link {
      display: flex;
      align-items: center;
      gap: .5rem;
      min-width: 0;
    }

    .group-label {
      width: 100%;
    }

    .large {
      font-size: var(--sl-text-base);
      font-weight: 600;
    }

    .individual,
    a {
      font-size: var(--sl-text-sm);
    }

    .caret {
      flex-shrink: 0;
      margin-inline-start: auto;
      transition: transform .2s ease;
    }

    details[open] > summary .caret {
      transform: rotate(90deg);
    }

    :global([dir='rtl']) .caret {
      transform: rotate(180deg);
    }

    :global([dir='rtl']) details[open] > summary .caret {
      transform: rotate(90deg);
    }

    [aria-current='page'] {
      color: var(--sl-color-accent);
      font-weight: 600;
    }
  }
</style>
