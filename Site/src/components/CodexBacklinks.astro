---
import graph from '../data/graph.json';

const { starlightRoute } = Astro.locals;
const currentId = String(starlightRoute.entry.data.slug ?? starlightRoute.entry.id)
  .replace(/\.(md|mdx)$/, '')
  .replace(/^\/+|\/+$/g, '');
const nodeById = new Map(graph.nodes.map((node) => [node.id, node]));
const backlinks = [
  ...new Set(graph.edges.filter((edge) => edge.target === currentId).map((edge) => edge.source)),
].filter((id) => nodeById.has(id));

function routeFor(id) {
  return id === 'index' ? '/' : `/${id}/`;
}
---

{backlinks.length > 0 ? (
  <ul class="codex-backlinks">
    {backlinks.map((id) => {
      const node = nodeById.get(id);
      return (
        <li>
          <a href={routeFor(id)}>{node?.title ?? id}</a>
        </li>
      );
    })}
  </ul>
) : (
  <p class="codex-empty-state">No backlinks yet.</p>
)}
