---
import SidebarSublist from './IonSidebarSublist.astro';

const { sidebar } = Astro.locals.starlightRoute;
const changelogSidebarLabel = 'Releases';
const isChangelogGroup = (entry: any) =>
  entry.type === 'group' && entry.label.split(']').pop()?.trim() === changelogSidebarLabel;
const changelogSidebar = sidebar.filter(isChangelogGroup);
const mainSidebar = sidebar.filter((entry: any) => !isChangelogGroup(entry));
const mainGroups = mainSidebar.filter((entry: any) => entry.type === 'group');
const mainArticles = mainSidebar.filter((entry: any) => entry.type === 'link');
---

<div class="codex-sidebar-layout">
  <div class="codex-sidebar-main">
    <SidebarSublist sublist={mainGroups} />
  </div>
  {changelogSidebar.length > 0 && (
    <aside class="codex-changelog-sidebar" aria-label="Releases">
      <SidebarSublist sublist={changelogSidebar} />
    </aside>
  )}
  {mainArticles.length > 0 && (
    <div class="codex-sidebar-articles">
      <SidebarSublist sublist={mainArticles} />
    </div>
  )}
</div>

<style>
  @layer starlight.core {
    .codex-sidebar-layout {
      box-sizing: border-box;
      display: flex;
      min-block-size: 100%;
      flex-direction: column;
    }

    .codex-sidebar-main {
      flex: 0 0 auto;
    }

    .codex-sidebar-articles {
      margin-block-start: .5rem;
    }

    .codex-changelog-sidebar {
      margin-block-start: 1.25rem;
      padding: 0;
      border: 0;
      border-radius: 0;
      background: transparent;
      box-shadow: none;
      color: var(--sl-color-gray-3);
    }

    @media (min-width: 50rem) {
      .codex-sidebar-layout {
        min-block-size: calc(100dvh - var(--sl-nav-height, 3.5rem) - 1.5rem);
      }

      .codex-changelog-sidebar {
        padding-block-start: 1rem;
      }
    }

    .codex-changelog-sidebar :global(.top-level) {
      margin: 0;
    }

    .codex-changelog-sidebar :global(.top-level > li + li) {
      margin-top: .2rem;
    }

    .codex-changelog-sidebar :global(summary) {
      margin: 0 0 .15rem;
      border-top: 0;
      padding-block: 0;
      color: var(--sl-color-gray-3);
    }

    .codex-changelog-sidebar :global(.group-label),
    .codex-changelog-sidebar :global(.flex-link) {
      gap: .35rem;
    }

    .codex-changelog-sidebar :global(.large) {
      color: var(--sl-color-gray-3);
      font-size: var(--sl-text-xs);
      letter-spacing: .1em;
      text-transform: uppercase;
    }

    .codex-changelog-sidebar :global(.caret) {
      color: var(--sl-color-gray-3);
      opacity: .65;
    }

    .codex-changelog-sidebar :global(a) {
      padding-block: .18rem;
      border: 0;
      background: transparent;
      color: var(--sl-color-gray-3);
      font-size: var(--sl-text-xs);
      opacity: .82;
    }

    .codex-changelog-sidebar :global(a:hover),
    .codex-changelog-sidebar :global(a:focus) {
      background: transparent;
      color: var(--sl-color-accent-high);
      opacity: 1;
      text-decoration: none;
    }
  }
</style>
