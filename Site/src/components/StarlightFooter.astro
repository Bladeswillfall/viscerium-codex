---
import LastUpdated from 'virtual:starlight/components/LastUpdated';
import Pagination from 'virtual:starlight/components/Pagination';
import CodexEditLink from './CodexEditLink.astro';
import GiscusComments from './GiscusComments.astro';
import LocalIcon from './LocalIcon.astro';
import siteConfig from '../../site.config.mjs';
---

<button
  class="codex-sidebar-toggle"
  type="button"
  data-codex-sidebar-toggle
  aria-expanded="true"
  aria-label="Hide sidebar"
  title="Hide sidebar"
>
  <span aria-hidden="true">←</span>
</button>

<GiscusComments />

<footer class="sl-flex">
  <div class="ion-codex-footer sl-flex">
    <strong>© VISCERIUM Codex</strong>
    <nav aria-label="Footer">
      <a href="/">Start Here</a>
      <a href="/graph/">World Graph</a>
      <a href={siteConfig.githubRepoUrl} target="_blank" rel="noreferrer">
        <LocalIcon name="github" />
        <span>GitHub</span>
      </a>
    </nav>
  </div>
  <div class="meta sl-flex">
    <CodexEditLink />
    <LastUpdated />
  </div>
  <Pagination />
</footer>

<script is:inline>
  (() => {
    const storageKey = 'viscerium-sidebar-collapsed';
    const root = document.documentElement;
    const button = document.querySelector('[data-codex-sidebar-toggle]');

    if (!button) return;

    const setCollapsed = (collapsed) => {
      root.classList.toggle('codex-sidebar-collapsed', collapsed);
      button.setAttribute('aria-expanded', String(!collapsed));
      button.setAttribute('aria-label', collapsed ? 'Show sidebar' : 'Hide sidebar');
      button.setAttribute('title', collapsed ? 'Show sidebar' : 'Hide sidebar');
      button.querySelector('span').textContent = collapsed ? '☰' : '←';
    };

    setCollapsed(localStorage.getItem(storageKey) === 'true');

    button.addEventListener('click', () => {
      const collapsed = !root.classList.contains('codex-sidebar-collapsed');
      localStorage.setItem(storageKey, String(collapsed));
      setCollapsed(collapsed);
    });
  })();
</script>

<style>
  @layer starlight.core {
    footer {
      flex-direction: column;
      gap: 1.5rem;
    }
    .meta {
      gap: 0.75rem 3rem;
      justify-content: space-between;
      flex-wrap: wrap;
      margin-top: 3rem;
      font-size: var(--sl-text-sm);
      color: var(--sl-color-gray-3);
    }
    .meta > :global(p:only-child) {
      margin-inline-start: auto;
    }
    .codex-edit-link {
      color: var(--sl-color-gray-3);
      text-decoration: none;
    }
    .codex-edit-link:hover {
      color: var(--sl-color-accent-high);
      text-decoration: underline;
    }
    .ion-codex-footer {
      gap: 1rem;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      margin-top: 3rem;
      padding: 1rem;
      border: 1px solid var(--sl-color-hairline-light);
      border-radius: 0.75rem;
      background: color-mix(in srgb, var(--sl-color-bg-nav) 88%, transparent);
      font-size: var(--sl-text-sm);
    }
    .ion-codex-footer nav {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.75rem 1rem;
    }
    .ion-codex-footer a {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      color: var(--sl-color-gray-2);
      text-decoration: none;
    }
    .ion-codex-footer a:hover {
      color: var(--sl-color-accent-high);
    }
  }
</style>
