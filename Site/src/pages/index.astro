---
import { getCollection } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import HomeGateway from '../components/home/HomeGateway.astro';
import HomeReveal from '../components/home/HomeReveal';
import timelineManifest from '../data/timelines/manifest.json';
import '../styles/homepage-styles';

const canonEntries = await getCollection('docs', ({ data }) => (
  data.publish === true
  && data.status === 'canon'
  && data.type !== 'category'
));
const globalTimelines = timelineManifest.timelines.filter(({ id }) => id === 'super');
const homepageStats = {
  canonEntryCount: canonEntries.length,
  mappedEventCount: globalTimelines.reduce((total, timeline) => total + timeline.eventCount, 0),
  unbrokenTimelineCount: globalTimelines.length,
};
---

<StarlightPage
  frontmatter={{
    title: 'VISCERIUM Codex',
    description: 'One timeline, four eras, infinite stories. Enter the public worldbuilding codex for VISCERIUM.',
    template: 'splash',
    pagefind: false,
    giscus: false,
  }}
  hasSidebar={true}
>
  <HomeReveal client:load />
  <HomeGateway {...homepageStats} />
</StarlightPage>
