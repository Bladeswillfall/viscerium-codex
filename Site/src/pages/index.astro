---
import { getCollection } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import timelineManifest from '../data/timelines/manifest.json';

const canonEntries = await getCollection('docs', ({ data }) => (
  data.publish === true
  && data.status === 'canon'
  && data.type !== 'category'
));

const globalTimelines = timelineManifest.timelines.filter(({ id }) => id === 'super');
const numberFormatter = new Intl.NumberFormat('en-GB');
const stats = {
  canon: numberFormatter.format(canonEntries.length),
  events: numberFormatter.format(
    globalTimelines.reduce((total, timeline) => total + timeline.eventCount, 0),
  ),
  timelines: numberFormatter.format(globalTimelines.length),
};

const eras = [
  {
    index: 'I',
    name: 'CITADEL',
    href: '/eras/citadel/',
    state: 'Fortified age',
    matter: 'Steel and bone',
    conflict: 'Dominions and cults',
    copy: 'Walled realms hold back famine, invasion and older things. Resonance remains ritual, early gunpowder is suspect, and the past is still mistaken for folklore.',
  },
  {
    index: 'II',
    name: 'SMOG',
    href: '/eras/smog/',
    state: 'Industrial age',
    matter: 'Soot and combustion',
    conflict: 'Blocs and trenches',
    copy: 'Industry mechanises inherited hatred. Sorcery meets noise fields, cities feed fronts, and every innovation becomes a faster way to ruin the same world.',
  },
  {
    index: 'III',
    name: 'NEARSIGHT',
    href: '/eras/nearsight/',
    state: 'Networked age',
    matter: 'Silicon and alloy',
    conflict: 'Proxies and platforms',
    copy: 'Satellites and remote weapons make the world visible without making it understood. Nations see everything close enough to target and almost nothing beyond it.',
  },
  {
    index: 'IV',
    name: 'ENTROPY',
    href: '/eras/entropy/',
    state: 'Interplanetary age',
    matter: 'Vacuum and altered flesh',
    conflict: 'Humanity, Zeniths, Myrkild',
    copy: 'The struggle leaves Errack. Human coalitions, angelic zealots and the Myrkild contest a system already scarred by conflicts nobody recognised in time.',
  },
];

const routes = [
  {
    index: '01',
    title: 'Start Here',
    href: '/start-here/',
    copy: 'The shortest route into Errack, the Degel System and the four eras.',
  },
  {
    index: '02',
    title: 'The Degel System',
    href: '/degel-system/degel/',
    copy: 'The star, worlds and hidden structures that contain the greater struggle.',
  },
  {
    index: '03',
    title: 'The Unbroken Timeline',
    href: '/timelines/super/',
    copy: 'Trace the events inherited from one age by the next.',
  },
  {
    index: '04',
    title: 'World Graph',
    href: '/graph/',
    copy: 'Follow the relationships between people, places, factions and ideas.',
  },
];
---

<StarlightPage
  frontmatter={{
    title: 'VISCERIUM Codex',
    description: 'One timeline, four eras, infinite stories. Enter the public worldbuilding codex for VISCERIUM.',
    template: 'splash',
    pagefind: false,
  }}
  hasSidebar={true}
>
  <div class="vc-home">
    <section class="vc-hero" aria-labelledby="vc-home-title">
      <div class="vc-hero__artifact" aria-hidden="true">
        <svg viewBox="0 0 1440 900" preserveAspectRatio="none">
          <path class="vc-scar" d="M741 -20C727 72 775 124 736 195c-29 54-4 103 23 151 30 54 17 102-13 151-32 53-7 108 19 153 31 53 23 111-17 165-22 30-20 71-7 105" />
          <path class="vc-scar" d="M733 -20c8 73-21 130 13 193 27 50 11 105-15 149-29 50-21 102 9 149 34 54 18 104-12 154-30 51-14 105 16 150 21 31 24 73 10 105" />
          <path class="vc-scar--active" d="M741 -20C727 72 775 124 736 195c-29 54-4 103 23 151 30 54 17 102-13 151-32 53-7 108 19 153 31 53 23 111-17 165-22 30-20 71-7 105" />
          <circle class="vc-scar-node vc-scar-node--open" cx="741" cy="176" r="7" />
          <circle class="vc-scar-node" cx="746" cy="351" r="7" />
          <circle class="vc-scar-node" cx="742" cy="535" r="7" />
          <circle class="vc-scar-node" cx="751" cy="717" r="7" />
        </svg>
      </div>

      <div class="vc-hero__copy">
        <h1 id="vc-home-title">VISCERIUM</h1>
        <div class="vc-hero__line">
          <strong>01:04</strong>
          <p>One wounded timeline, observed across four eras. The names change. The struggle survives them.</p>
        </div>
      </div>

      <aside class="vc-hero__aside" aria-label="Codex introduction and era index">
        <p>This is a public archive of a secondary world advancing from fortified kingdoms to interplanetary war without abandoning what came before.</p>

        <nav class="vc-era-index" aria-label="The four eras">
          <ol>
            {eras.map((era) => (
              <li>
                <a href={era.href}>
                  <b>{era.index}</b>
                  <span>{era.name}</span>
                  <small>{era.state}</small>
                </a>
              </li>
            ))}
          </ol>
        </nav>

        <a class="vc-enter" href="/start-here/">
          Enter the Codex
          <svg viewBox="0 0 20 20" aria-hidden="true">
            <path d="M5 15 15 5M7 5h8v8" />
          </svg>
        </a>
      </aside>
    </section>

    <section class="vc-manifesto" aria-labelledby="vc-manifesto-title">
      <h2 id="vc-manifesto-title">History does not reset when the weapons improve.</h2>
      <p>Kingdoms become republics. Ritual becomes science. Superstition survives inside doctrine, infrastructure and machines. Every era inherits the damage, discoveries and lies of the last.</p>
    </section>

    <ol class="vc-era-ledger" aria-label="Era ledger">
      {eras.map((era) => (
        <li>
          <a href={era.href} aria-label={`Explore ${era.name}`}>
            <span class="vc-era-ledger__number">ERA {era.index}</span>
            <h3>{era.name}</h3>
            <div class="vc-era-ledger__copy">
              <p>{era.copy}</p>
              <dl>
                <div><dt>Condition</dt><dd>{era.state}</dd></div>
                <div><dt>Material</dt><dd>{era.matter}</dd></div>
                <div><dt>Conflict</dt><dd>{era.conflict}</dd></div>
              </dl>
            </div>
          </a>
        </li>
      ))}
    </ol>

    <section class="vc-archive" aria-labelledby="vc-archive-title">
      <h2 id="vc-archive-title">The archive records what survived.</h2>
      <dl class="vc-archive__table">
        <div><dt>Historical eras</dt><dd>4</dd></div>
        <div><dt>Published canon records</dt><dd>{stats.canon}</dd></div>
        <div><dt>Mapped historical events</dt><dd>{stats.events}</dd></div>
        <div><dt>Unbroken master timelines</dt><dd>{stats.timelines}</dd></div>
      </dl>
    </section>

    <section class="vc-routes" aria-labelledby="vc-routes-title">
      <p id="vc-routes-title">The archive is deliberately large. These routes provide context before names, borders and doctrines begin to overlap.</p>
      <ol class="vc-route-list">
        {routes.map((route) => (
          <li>
            <a href={route.href}>
              <b>{route.index}</b>
              <strong>{route.title}</strong>
              <span>{route.copy}</span>
              <i aria-hidden="true">↗</i>
            </a>
          </li>
        ))}
      </ol>
    </section>
  </div>
</StarlightPage>
