---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { PageGraph } from 'starlight-site-graph/components';
---
<StarlightPage frontmatter={{ title: 'World Graph', description: 'Public links and relationships generated from the Obsidian vault.' }}>
  <div class="world-graph">
    <PageGraph slug="start-here" />
  </div>
</StarlightPage>

<script>
  async function hydrateWorldGraph() {
    const graph = document.querySelector('.world-graph graph-component[data-sitemap="{}"]');
    if (!graph) return;

    const base = import.meta.env.BASE_URL.endsWith('/')
      ? import.meta.env.BASE_URL
      : `${import.meta.env.BASE_URL}/`;
    const response = await fetch(`${base}sitegraph/sitemap.json`);
    if (!response.ok) throw new Error(`Site graph sitemap returned ${response.status}`);
    graph.setAttribute('data-sitemap', JSON.stringify(await response.json()));
  }

  const hydrate = () => void hydrateWorldGraph().catch(console.error);
  hydrate();
  document.addEventListener('astro:page-load', hydrate);
</script>
