{
  "name": "viscerium-codex",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/build-content.mjs --mode=dev && astro dev",
    "dev:sync": "npm run dev",
    "validate:vault": "node scripts/validate-vault-notes.mjs",
    "validate:timelines": "node scripts/generate-timeline-data.mjs --validate-only",
    "validate:icons": "node scripts/validate-icon-output.mjs",
    "sync": "node scripts/build-content.mjs --mode=sync",
    "validate": "node scripts/validate-content.mjs",
    "generate:maps": "node scripts/generate-map-data.mjs",
    "generate:timelines": "node scripts/generate-timeline-data.mjs",
    "benchmark:timelines": "node scripts/benchmark-timelines.mjs",
    "test:unit": "node --test tests/*.test.mjs",
    "prebuild": "node scripts/build-content.mjs --mode=build",
    "build": "astro build",
    "postbuild": "npm run validate:icons",
    "preview": "astro preview",
    "astro": "astro",
    "test": "npm run test:unit && npm run build"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "7.2.1",
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/preact": "6.0.1",
    "@astrojs/sitemap": "3.7.3",
    "@astrojs/starlight": "^0.41.3",
    "astro": "^7.1.1",
    "chronos-timeline-md": "1.1.0",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.22",
    "preact": "10.29.7",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "starlight-changelogs": "^0.5.0",
    "starlight-giscus": "^1.1.0",
    "starlight-scroll-to-top": "^1.0.1",
    "starlight-sidebar-swipe": "^0.2.0",
    "starlight-site-graph": "^0.5.0",
    "starlight-tags": "^1.0.1",
    "starlight-telescope": "^1.0.0",
    "vis-timeline": "8.5.1"
  },
  "engines": {
    "node": ">=22.17.0"
  },
  "overrides": {
    "picomatch": "^4.0.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
