{
  "name": "obsidian-starlight-codex-template",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "dev:sync": "npm run sync && astro dev",
    "sync": "node scripts/sync-public-notes.mjs",
    "validate": "node scripts/validate-content.mjs",
    "generate:graph": "node scripts/generate-graph.mjs",
    "generate:maps": "node scripts/generate-map-data.mjs",
    "generate:timelines": "node scripts/generate-timeline-data.mjs",
    "prebuild": "npm run sync && npm run validate && npm run generate:graph && npm run generate:maps && npm run generate:timelines",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "npm run build"
  },
  "dependencies": {
    "@astrojs/sitemap": "latest",
    "@astrojs/starlight": "latest",
    "astro": "latest",
    "fast-glob": "^3.3.3",
