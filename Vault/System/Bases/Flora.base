filters:
  and:
    - type == "flora"
    - '!file.inFolder("Templates")'
properties:
  title:
    displayName: Flora
  description:
    displayName: Identity
  growth_form:
    displayName: Growth form
  eras:
    displayName: Eras
  locations:
    displayName: Locations
  biomes:
    displayName: Biomes
  rarity:
    displayName: Rarity
  growth_conditions:
    displayName: Growth conditions
  human_relevance:
    displayName: Why people care
  hazards:
    displayName: Hazards
  development_level:
    displayName: Development
  image:
    displayName: Artwork
views:
  - type: cards
    name: Flora Cards
    order:
      - title
      - description
      - growth_form
      - eras
      - locations
      - biomes
      - rarity
      - growth_conditions
      - human_relevance
      - hazards
      - development_level
    sort:
      - property: title
        direction: ASC
    cardSize: 260
    imageFit: cover
    imageAspectRatio: 1.5
    image: image
  - type: table
    name: Database
    order:
      - title
      - growth_form
      - eras
      - locations
      - biomes
      - rarity
      - identification
      - signs_of_presence
      - growth_conditions
      - ecological_relationships
      - human_relevance
      - hazards
      - cultural_significance
      - story_complication
      - development_level
      - status
      - file.mtime
    sort:
      - property: title
        direction: ASC
